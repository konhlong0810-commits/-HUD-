<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- 顶栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="@android:color/white"
        android:elevation="1dp">
        <TextView android:id="@+id/tvUser" android:layout_width="0dp" android:layout_weight="1"
            android:textSize="14sp" android:textColor="#2563EB" />
        <TextView android:id="@+id/gpsBadge" android:layout_width="wrap_content"
            android:text="GPS" android:textSize="11sp" android:textColor="#D97706"
            android:background="#FFFBEB" android:paddingStart="8dp" android:paddingEnd="8dp"
            android:paddingTop="3dp" android:paddingBottom="3dp" />
    </LinearLayout>

    <!-- 速度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:gravity="center"
        android:orientation="vertical">
        <TextView android:id="@+id/tvSpeed" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="0" android:textSize="80sp"
            android:textColor="#1E293B" android:fontFamily="sans-serif-medium" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="公里/时" android:textSize="14sp" android:textColor="#64748B" />
    </LinearLayout>

    <!-- 数据面板 -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="8dp">
        <LinearLayout android:orientation="vertical" android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout android:orientation="vertical" android:background="@android:color/white"
                android:padding="12dp" android:layout_marginBottom="6dp" android:elevation="1dp">
                <TextView android:text=" GPS 定位" android:textSize="12sp" android:textColor="#2563EB" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvCoord" android:text="--" android:textSize="13sp"
                    android:textColor="#1E293B" android:fontFamily="monospace" android:layout_marginBottom="2dp"/>
                <TextView android:id="@+id/tvGpsInfo" android:text="--" android:textSize="12sp"
                    android:textColor="#64748B" android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout android:orientation="vertical" android:background="@android:color/white"
                android:padding="12dp" android:layout_marginBottom="6dp" android:elevation="1dp">
                <TextView android:text=" 运动传感器" android:textSize="12sp" android:textColor="#2563EB" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvAccel" android:text="加速度: --" android:textSize="12sp"
                    android:textColor="#1E293B" android:fontFamily="monospace" android:layout_marginBottom="1dp"/>
                <TextView android:id="@+id/tvGyro" android:text="陀螺仪: --" android:textSize="12sp"
                    android:textColor="#1E293B" android:fontFamily="monospace" android:layout_marginBottom="1dp"/>
                <TextView android:id="@+id/tvPressure" android:text="气压: --" android:textSize="12sp"
                    android:textColor="#1E293B" android:fontFamily="monospace" android:layout_marginBottom="1dp"/>
                <TextView android:id="@+id/tvHeading" android:text="航向: --" android:textSize="12sp"
                    android:textColor="#1E293B" android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout android:orientation="vertical" android:background="@android:color/white"
                android:padding="12dp" android:elevation="1dp">
                <TextView android:text=" 本次行程" android:textSize="12sp" android:textColor="#2563EB" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvDist" android:text="里程: --" android:textSize="13sp"
                    android:textColor="#1E293B" android:fontFamily="monospace" android:layout_marginBottom="1dp"/>
                <TextView android:id="@+id/tvDur" android:text="时长: --" android:textSize="13sp"
                    android:textColor="#1E293B" android:fontFamily="monospace"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 底部 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
        android:orientation="horizontal" android:background="@android:color/white"
        android:elevation="4dp" android:weightSum="3">
        <Button android:id="@+id/btnHistory" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text=" 历史" android:textSize="13sp"
            android:textColor="#64748B" style="?android:attr/borderlessButtonStyle"/>
        <Button android:id="@+id/btnRank" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text=" 排行" android:textSize="13sp"
            android:textColor="#64748B" style="?android:attr/borderlessButtonStyle"/>
        <Button android:id="@+id/btnLogout" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="退出" android:textSize="13sp"
            android:textColor="#EF4444" style="?android:attr/borderlessButtonStyle"/>
    </LinearLayout>
</LinearLayout>
